# -------------------------------------------------------
# Server environment variables
# -------------------------------------------------------

# Set to 'production' to disable all dev endpoints/events.
# Any other value (e.g. 'development', 'test') enables dev mode.
NODE_ENV=development

# Secret token required for dev:setScenario socket event.
# Must be non-empty for the dev handler to accept requests.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DEV_SECRET=change-me-to-a-random-secret

# Base32-encoded TOTP secret for admin authentication.
# Generate with: node -e "const b='ABCDEFGHIJKLMNOPQRSTUVWXYZ234567';let s='';for(let i=0;i<32;i++)s+=b[Math.floor(Math.random()*32)];console.log(s)"
# Then scan the resulting secret with an authenticator app (e.g. Google Authenticator):
#   otpauth://totp/MafiaWebGame%3Aadmin?secret=<YOUR_SECRET>&issuer=MafiaWebGame
# Leave empty to disable admin login.
ADMIN_TOTP_SECRET=change-me-to-a-base32-secret

# Allowed client origin for CORS (defaults to http://localhost:5173)
CLIENT_ORIGIN=http://localhost:5173

# -------------------------------------------------------
# Client environment variables (prefix with VITE_)
# -------------------------------------------------------

# Pre-fill the DEV_SECRET field in the /dev panel (optional convenience).
# Never set this in a production build.
VITE_DEV_SECRET=change-me-to-a-random-secret

# Server URL used by the client for admin HTTP calls (defaults to http://localhost:3001)
VITE_SERVER_URL=http://localhost:3001

# -------------------------------------------------------
# Server environment variables
# -------------------------------------------------------

# Set to 'production' to disable all dev endpoints/events.
# Any other value (e.g. 'development', 'test') enables dev mode.
NODE_ENV=development

# Secret token required for dev:setScenario socket event.
# Must be non-empty for the dev handler to accept requests.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DEV_SECRET=change-me-to-a-random-secret

# -------------------------------------------------------
# Client environment variables (prefix with VITE_)
# -------------------------------------------------------

# Pre-fill the DEV_SECRET field in the /dev panel (optional convenience).
# Never set this in a production build.
VITE_DEV_SECRET=change-me-to-a-random-secret
